# Environment variables needed to connect to the LiveKit server.
LIVEKIT_API_KEY=<your_api_key>
LIVEKIT_API_SECRET=<your_api_secret>
LIVEKIT_URL=wss://<project-subdomain>.livekit.cloud


# Optional: keep empty to use /api/connection-details on the same frontend service.
# Set this only if you run a separate token service endpoint.
NEXT_PUBLIC_CONN_DETAILS_ENDPOINT=


# Internally used environment variables
NEXT_PUBLIC_APP_CONFIG_ENDPOINT=
SANDBOX_ID=
